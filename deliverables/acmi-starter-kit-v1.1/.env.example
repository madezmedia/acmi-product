# ACMI MCP Server Environment Configuration
# Copy this file to .env and fill in your actual values

# === REQUIRED: Upstash Redis Connection ===
UPSTASH_REDIS_REST_URL=https://<your-redis-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-redis-token>

# === OPTIONAL: Model API Keys (for summarization/LLM operations) ===
# Uncomment and configure if you plan to use LLM-based features
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=AIzaSy...
# GLM_API_KEY=...

# === OPTIONAL: Webhook Integration ===
# Configure if integrating with external services
# SLACK_BOT_TOKEN=xapp-...
# SLACK_APP_TOKEN=xapp-...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ALLOWED_USERS=123456789

# === OPTIONAL: Email Integration ===
# EMAIL_ADDRESS=your-email@domain.com
# EMAIL_PASSWORD=<app-specific-password>
# EMAIL_IMAP_HOST=imap.provider.com
# EMAIL_SMTP_HOST=smtp.provider.com

# === OPTIONAL: Filesystem Paths ===
# MESSAGING_CWD=/path/to/your/workspace
# TERMINAL_ENV=local

# === OPTIONAL: Browser Configuration ===
# AGENT_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# BROWSER_SESSION_TIMEOUT=300
# BROWSER_INACTIVITY_TIMEOUT=120

# === ACMI Configuration ===
# Namespace defaults (can be overridden at runtime)
# ACMI_DEFAULT_NAMESPACE=production

# === Security Notes ===
# 1. Never commit this file to version control
# 2. Rotate tokens regularly
# 3. Use environment-specific values for dev/staging/production
# 4. Consider using secret management services for production deployments